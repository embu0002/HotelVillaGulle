---
// Henter parametrene fra Astro.props
const { htmlheading = "h2", size = "small", font = "sans", stylingclasses = "" } = Astro.props;
const Htmlheading = htmlheading;

const sizeClasses = {
  xlarge: "text-[2rem] lg:text-[3.625rem]", // H1 - Mobil: 32px, Web: 58px
  large: "text-[1.5rem] lg:text-[2.5rem]", // H2 - Mobil: 24px, Web: 48px
  medium: "text-[1.1rem] lg:text-[1.3rem]", // H3 - Mobil: 20px, Web: 32px
  small: "text-[1rem] lg:text-[1.25rem] font-bold", // H4 - Mobil: 19px, Web: 24px
  xsmall: "text-[0.875rem] lg:text-[1rem]", // H5 - Mobil: 18px, Web: 20px

  knap: "text-[0.9375rem] lg:text-[1.375rem] font-bold", // Mobil: 15px, Web: 22px
  hero: "text-[2rem] lg:text-[4rem]", // Mobil: 32px, Web: 70px
};

//Definer den styling (Tailwind classes), der gør sig gældende for de forskellige skrifttyper.
const fontClasses = {
  display: "font-display",
  sans: "font-sans",
  serif: "font-serif",
  alexbrush: "font-alex-brush",
};
---

<Htmlheading class:list={[stylingclasses, sizeClasses[size], fontClasses[font]]}><slot /></Htmlheading>
