---
import Heading from "../Heading.astro";
import Text from "../Text.astro";
import Button from "../Button.astro";

const { data, variant = "browse" } = Astro.props;

const name = data.name;
const description = data.description;
const price = data.price_per_night;
const image = data.image;
const slug = data.slug;

const isSelect = variant === "select";
---

<article class="w-full max-w-[920px] grid gap-6 p-7 rounded-md shadow-md bg-[var(--color-secondary-beige-50)] md:grid-cols-[2fr_3fr]">
  <img src={image} alt={name} class="w-full object-cover h-auto max-h-[320px] rounded-2xl md:rounded-md" />

  <div class="flex flex-col justify-between py-3 gap-6">
    <!-- Titel + beskrivelse -->
    <div class="flex flex-col gap-3">
      <Heading htmlheading="h2" size="medium" font="display" stylingclasses="font-light">
        {name}
      </Heading>
      <Text teksttype="brødtekst" stylingclasses="font-light text-gray-700 max-w-prose line-clamp-7">
        {description}
      </Text>
    </div>

  <!-- Pris + knapper -->
{isSelect ? (
  <!-- SELECT: pris over, begge knapper nedenunder -->
  <div class="flex flex-col gap-3">
    <Heading htmlheading="h4" size="small" font="display">
      Fra {price} dkk
    </Heading>
    <div class="flex items-center justify-between gap-3">
      <a href={`/rooms/${slug}`}>
        <Button variant="secondary" size="small">Mere info</Button>
      </a>
      <a href="#" class="choose-room" data-room-id={data.id}>
        <Button variant="primary" size="small">Vælg</Button>
      </a>
    </div>
  </div>
) : (
  <div class="flex items-center justify-between gap-3">
  <Heading htmlheading="h4" size="small" font="display">
    Fra {price} dkk
  </Heading>
  <a id={`more-info-${data.id}`} href={`/rooms/${slug}`}>
  <Button variant="secondary" size="small">Mere info</Button>
</a>
</div>
)}
  </div>
</article>
<script define:vars={{ roomSlug: slug, roomId: data.id }}>
  document.addEventListener("DOMContentLoaded", () => {
    const btn = document.getElementById(`more-info-${roomId}`);
    if (btn) {
      const params = new URLSearchParams(window.location.search);
      btn.href = `/rooms/${roomSlug}?${params.toString()}`;
    }
  });
  console.log("roomId:", roomId, "slug:", roomSlug);
</script>
<script>
  document.querySelectorAll(".choose-room").forEach((btn) => {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      const params = new URLSearchParams(window.location.search);
      params.set("room", btn.dataset.roomId);
      window.location.href = `/book_step3?${params.toString()}`;
    });
  });
</script>

