---
// AktiviteterCard.astro
import Heading from "./Heading.astro";
import Text from "./Text.astro";

interface AktivitetItem {
  title: string;
  body?: string;
  image: string;
  imageAlt?: string;
  href?: string;
}

interface Props {
  items: AktivitetItem[];
}

const { items } = Astro.props;
---

{/* MOBIL — horizontal slider */}
<div class="lg:hidden relative">
  {/* Pile */}
  <button id="prev" aria-label="Forrige" class="absolute left-2 top-1/2 -translate-y-1/2 z-10 bg-white/80 hover:bg-white rounded-full w-9 h-9 flex items-center justify-center shadow transition">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"></polyline>
    </svg>
  </button>
  <button id="next" aria-label="Næste" class="absolute right-2 top-1/2 -translate-y-1/2 z-10 bg-white/80 hover:bg-white rounded-full w-9 h-9 flex items-center justify-center shadow transition">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="9 18 15 12 9 6"></polyline>
    </svg>
  </button>

  {/* Scroll container */}
  <div id="slider" class="flex overflow-x-auto gap-4 px-8 py-4 snap-x snap-mandatory scroll-smooth scrollbar-hide" style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;">
    {
      items.map((item) => (
        <a href={item.href ?? "#"} class="group relative shrink-0 w-[80vw] aspect-[3/4] overflow-hidden rounded snap-center block">
          <img src={item.image} alt={item.imageAlt ?? item.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent" />
          <div class="absolute bottom-0 left-0 right-0 p-10">
            <Heading htmlheading="h3" size="medium" font="display" stylingclasses="text-white font-light mb-2">
              {item.title}
            </Heading>
            {item.body && (
              <Text teksttype="brødtekst" stylingclasses="text-white/80 font-light line-clamp-4">
                {item.body}
              </Text>
            )}
          </div>
        </a>
      ))
    }
  </div>
</div>

{/* DESKTOP — grid */}
<div class="hidden lg:grid grid-cols-3 gap-10">
  {
    items.map((item) => (
      <a href={item.href ?? "#"} class="group relative h-[550px] overflow-hidden block">
        {/* Billede */}
        <img src={item.image} alt={item.imageAlt ?? item.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />

        {/* Gradient */}
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent" />

        {/* Tekst ovenpå */}
        <div class="absolute inset-0 flex flex-col justify-end p-8">
          <Heading htmlheading="h3" size="medium" font="display" stylingclasses="text-white font-light mb-3">
            {item.title}
          </Heading>
          {item.body && (
            <Text teksttype="brødtekst" stylingclasses="text-white/80 font-light">
              {item.body}
            </Text>
          )}
        </div>
      </a>
    ))
  }
</div>

<script>
  const slider = document.getElementById("slider");
  const prev = document.getElementById("prev");
  const next = document.getElementById("next");

  function getCardWidth() {
    const card = slider?.querySelector("a");
    if (!card) return 0;
    return card.getBoundingClientRect().width + 16; // width + gap-4
  }

  prev?.addEventListener("click", () => {
    slider?.scrollBy({ left: -getCardWidth(), behavior: "smooth" });
  });

  next?.addEventListener("click", () => {
    slider?.scrollBy({ left: getCardWidth(), behavior: "smooth" });
  });
</script>

<style>
  /* Skjul scrollbar på alle browsere */
  #slider {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #slider::-webkit-scrollbar {
    display: none;
  }
</style>
