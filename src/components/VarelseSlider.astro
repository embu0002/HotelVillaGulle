---
import Button from "./Button.astro";
import Heading from "./Heading.astro";
import Text from "./Text.astro";

interface SlideItem {
  title: string;
  description: string;
  price: string;
  bookingHref: string;
  image: { src: string; alt: string };
}
interface Props {
  slides: SlideItem[];
}
const { slides } = Astro.props;
---

<section style="--page-padding: clamp(1rem, 5vw, 2.5rem); padding: var(--page-padding)">
  <div class="vaerrelse-slider select-none">
    {/* Tekst-sektion — ingen overflow-hidden her */}
    <div class="mb-6 overflow-hidden">
      <div data-text-track class="flex transition-transform duration-500 ease-in-out">
        {
          slides.map((slide) => (
            <div class="min-w-full flex flex-col gap-0">
              <Heading htmlheading="h2" size="large" font="display" stylingclasses="font-light mb-1">
                {slide.title}
              </Heading>
              <Text teksttype="brødtekst" stylingclasses="font-light text-gray-700 max-w-prose mb-1">
                {slide.description}
              </Text>
              <Heading htmlheading="h4" size="small" font="display" stylingclasses=" mb-3">
                Fra {slide.price}
              </Heading>

              <a href={slide.bookingHref} class="w-fit">
                <Button variant="primary" size="small">
                  Book nu
                </Button>
              </a>
            </div>
          ))
        }
      </div>
    </div>

    {/* Karussel + pile-knapper */}
    <div class="relative">
      <button data-prev aria-label="Forrige værelse" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-1/2 z-20
               w-10 h-10 rounded-full bg-white/90 shadow-md
               flex items-center justify-center
               hover:bg-white active:scale-95 transition-all duration-200">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>

      <button data-next aria-label="Næste værelse" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 z-20
               w-10 h-10 rounded-full bg-white/90 shadow-md
               flex items-center justify-center
               hover:bg-white active:scale-95 transition-all duration-200" style="right: calc(-1 * var(--page-padding, 2rem))">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

      {/* Karussel — bryder ud til højre */}
      <div data-overflow class="vaerrelse-slider__overflow overflow-hidden cursor-grab active:cursor-grabbing" style="margin-right: calc(-1 * var(--page-padding, 2rem));">
        <div data-rail class="flex items-center transition-transform duration-500 ease-in-out" style="gap: 2rem;">
          {
            slides.map((slide, i) => (
              <div data-card data-index={i} class="shrink-0 overflow-hidden transition-all duration-500">
                <img src={slide.image.src} alt={slide.image.alt} class="w-full h-full object-cover block pointer-events-none" loading="lazy" />
              </div>
            ))
          }
        </div>
      </div>
    </div>

    {/* Dots */}
    <div class="flex justify-center gap-3 mt-6">
      {slides.map((_, i) => <button data-dot data-index={i} aria-label={`Gå til slide ${i + 1}`} class={`w-2.5 h-2.5 rounded-full border transition-all duration-300 ${i === 0 ? "bg-[#2d4a3e] border-[#2d4a3e] scale-110" : "bg-transparent border-[#2d4a3e]"}`} />)}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll(".vaerrelse-slider").forEach((slider) => {
    const textTrack = slider.querySelector("[data-text-track]") as HTMLElement;
    const rail = slider.querySelector("[data-rail]") as HTMLElement;
    const overflow = slider.querySelector("[data-overflow]") as HTMLElement;
    const dots = slider.querySelectorAll("[data-dot]") as NodeListOf<HTMLButtonElement>;
    const cards = slider.querySelectorAll("[data-card]") as NodeListOf<HTMLElement>;
    const prevBtn = slider.querySelector("[data-prev]") as HTMLButtonElement;
    const nextBtn = slider.querySelector("[data-next]") as HTMLButtonElement;
    const total = cards.length;
    const GAP = 8;
    let current = 0;

    // ── Dimensioner ──────────────────────────────────────────────────────────
    function getSizes() {
      const wrapperW = overflow.offsetWidth;
      const isMobile = window.innerWidth < 768;
      const largeW = Math.round(wrapperW * (isMobile ? 0.65 : 0.3));
      const smallW = Math.round(wrapperW * (isMobile ? 0.22 : 0.16));
      const largeH = Math.round(largeW * (3 / 2)); // 2:3 lodret — passer til portræt-billeder
      const smallH = Math.round(smallW * (3 / 2)); // SAMME ratio på små kort
      return { largeW, smallW, largeH, smallH };
    }

    // ── Layout ───────────────────────────────────────────────────────────────
    function applyLayout(animate = false) {
      const { largeW, smallW, largeH, smallH } = getSizes();
      cards.forEach((card, i) => {
        card.style.transition = animate ? "width 500ms ease, height 500ms ease" : "none";
        card.style.width = i === current ? `${largeW}px` : `${smallW}px`;
        card.style.height = i === current ? `${largeH}px` : `${smallH}px`;
      });
      if (!animate) {
        void rail.offsetHeight;
        cards.forEach((c) => (c.style.transition = ""));
      }
    }

    // ── Rail-offset ───────────────────────────────────────────────────────────
    function getRailOffset() {
      const { smallW } = getSizes();
      let offset = 0;
      for (let i = 0; i < current; i++) offset += smallW + GAP;
      return offset;
    }

    // ── goTo ──────────────────────────────────────────────────────────────────
    function goTo(index: number) {
      current = ((index % total) + total) % total;
      textTrack.style.transform = `translateX(${-current * 100}%)`;
      applyLayout(true);
      rail.style.transform = `translateX(${-getRailOffset()}px)`;
      dots.forEach((dot, i) => {
        dot.classList.toggle("bg-[#2d4a3e]", i === current);
        dot.classList.toggle("bg-transparent", i !== current);
        dot.classList.toggle("scale-110", i === current);
      });
    }

    // ── Init ──────────────────────────────────────────────────────────────────
    requestAnimationFrame(() => {
      applyLayout(false);
      rail.style.transform = "translateX(0)";
    });

    window.addEventListener("resize", () => {
      applyLayout(false);
      goTo(current);
    });

    // ── Knapper ───────────────────────────────────────────────────────────────
    prevBtn.addEventListener("click", () => goTo(current - 1));
    nextBtn.addEventListener("click", () => goTo(current + 1));

    // ── Dots ──────────────────────────────────────────────────────────────────
    dots.forEach((dot) => {
      dot.addEventListener("click", () => goTo(Number(dot.dataset.index)));
    });

    // ── Klik på kort ──────────────────────────────────────────────────────────
    cards.forEach((card) => {
      card.addEventListener("click", () => {
        if (didDrag) return;
        const idx = Number(card.dataset.index);
        if (idx !== current) goTo(idx);
      });
    });

    // ── Mus-drag ──────────────────────────────────────────────────────────────
    let dragStartX = 0;
    let dragStartY = 0;
    let isDragging = false;
    let didDrag = false;

    overflow.addEventListener("mousedown", (e: MouseEvent) => {
      if ((e.target as HTMLElement).closest("button")) return;
      isDragging = true;
      didDrag = false;
      dragStartX = e.clientX;
      dragStartY = e.clientY;
      e.preventDefault();
    });

    window.addEventListener("mousemove", (e: MouseEvent) => {
      if (!isDragging) return;
      if (Math.abs(e.clientX - dragStartX) > 5) didDrag = true;
    });

    window.addEventListener("mouseup", (e: MouseEvent) => {
      if (!isDragging) return;
      isDragging = false;
      const dx = dragStartX - e.clientX;
      const dy = dragStartY - e.clientY;
      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 60) {
        goTo(dx > 0 ? current + 1 : current - 1);
      }
      setTimeout(() => {
        didDrag = false;
      }, 0);
    });

    // ── Touch ─────────────────────────────────────────────────────────────────
    let touchStartX = 0;
    let touchStartY = 0;
    let touchDir: "h" | "v" | null = null;

    overflow.addEventListener(
      "touchstart",
      (e: TouchEvent) => {
        touchStartX = e.touches[0].clientX;
        touchStartY = e.touches[0].clientY;
        touchDir = null;
      },
      { passive: true },
    );

    overflow.addEventListener(
      "touchmove",
      (e: TouchEvent) => {
        if (touchDir === "v") return;
        const dx = e.touches[0].clientX - touchStartX;
        const dy = e.touches[0].clientY - touchStartY;
        if (touchDir === null && (Math.abs(dx) > 5 || Math.abs(dy) > 5)) {
          touchDir = Math.abs(dx) > Math.abs(dy) ? "h" : "v";
        }
        if (touchDir === "h") e.preventDefault();
      },
      { passive: false },
    );

    overflow.addEventListener("touchend", (e: TouchEvent) => {
      if (touchDir !== "h") return;
      const dx = touchStartX - e.changedTouches[0].clientX;
      if (Math.abs(dx) > 40) goTo(dx > 0 ? current + 1 : current - 1);
    });
  });
</script>
