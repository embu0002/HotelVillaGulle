---
import Heading from "./Heading.astro";
import Text from "./Text.astro";

const { icon, title, text } = Astro.props;
---

<div class="bg-secondary-beige-100 md:p-12 flex flex-col items-center text-center aspect-square max-w-[280px] md:max-w-[500px]">
  <img src={icon} alt={title} class="w-9 h-9 mb-3 mt-10 md:w-15 md:h-15 md:mb-5" />

  <Heading htmlheading="h3" size="medium" font="display" stylingclasses="mb-3md:mb-5">
    {title}
  </Heading>

  <Text teksttype="brødtekst" stylingclasses="max-w-[260px] text-center">
    {text}
  </Text>
</div>
