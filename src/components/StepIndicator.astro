---
import Heading from "./Heading.astro";
const { currentStep = 1 } = Astro.props;

const steps = ["Vælg dato", "Vælg værelse", "Betaling", "Bekræftelse"];
---

<div class="stepper mb-10">
  {
    steps.map((label, index) => {
      const stepNumber = index + 1;
      const isActive = stepNumber === currentStep;
      const isCompleted = stepNumber < currentStep;

      return (
        <div class="step">
          <div class="visual">
            {/* <div class={`circle ${isActive ? "active" : ""} ${isCompleted ? "done" : ""}`} /> */}
            <div class={`circle ${isActive ? "active" : ""}`} />
            {index < steps.length - 1 && <div class="line" />}
          </div>

          <Heading htmlheading="h5" size="xsmall" font="display" stylingclasses="label">
            {label}
          </Heading>
        </div>
      );
    })
  }
</div>

<style>
  .circle {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: transparent;
    border: 2px solid var(--color-primary-neutral-950);
    z-index: 2;
  }

  /* aktiv */
  .circle.active {
    background: var(--color-primary-green-900);
    border-color: var(--color-primary-green-900);
  }

  /* completed (valgfri) */
  /* .circle.done {
    background: var(--color-primary-green-900);
    border-color: var(--color-primary-green-900);
  } */

  /* linje */
  .line {
    width: 60px;
    height: 2px;
    background: var(--color-primary-neutral-950);
    margin: 0 8px;
  }

  /* aktiv */
  .circle.active {
    background: var(--color-primary-green-900);
    border-color: var(--color-primary-green-900);
  }

  /* completed (valgfri) */
  .circle.done {
    background: var(--color-primary-green-900);
    border-color: var(--color-primary-green-900);
  }

  /* tekst */
  .step span {
    position: absolute;
    top: 40px;
    font-size: 0.85rem;
    white-space: nowrap;
    left: 50%;
    transform: translateX(-50%);
  }
  .stepper {
    display: flex;
    justify-content: center;
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    margin-right: 60px; /* samme som line width */
  }

  .step:last-child {
    margin-right: 0;
  }

  .visual {
    position: relative;
    display: flex;
    justify-content: center;
    width: 40px; /* samme som cirkel */
  }

  .line {
    position: absolute;
    left: 100%;
    top: 50%;
    transform: translateY(-50%);
    width: 60px;
    height: 2px;
    background: var(--color-primary-neutral-950);
  }

  /* label */
  .label {
    margin-top: 0.5rem;
    text-align: center;
    white-space: nowrap;
  }
</style>
