---
import MainLayout from "../layouts/MainLayout.astro";
import Link from "../components/Link.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import Button from "../components/Button.astro";
import DropdownSection from "../components/Dropdownsection.astro";
import HeroPages from "../components/HeroPages.astro";
import AktiviteterCard from "../components/AktiviteterCard.astro";
import InfoCard from "../components/InfoCard.astro";

const infoCards = [
  {
    icon: "/infografik_ur.png",
    title: "Check-in & Check-ud",
    text: "Check-in fra kl. 15:00. Check-out senest kl. 11:00.",
  },
  {
    icon: "/infografik_morgenmad.png",
    title: "Morgenmad",
    text: "Mandag til fredag fra 07.30-09.00 Lørdag til søndag fra 08.00-10.00",
  },
  {
    icon: "/infografik_parkering.png",
    title: "Parkering",
    text: "Hotellets gårdplads tilbyder gratis parkering efter først-til-mølle.",
  },
  {
    icon: "/inforgrafik_hund.png",
    title: "Kæledyr",
    text: "Det er ikke tilladt at medbringe kæledyr på Hotel Villa Gulle.",
  },
  {
    icon: "/infografik_baby.png",
    title: "Babyseng",
    text: "Vi tilbyder lån af babyseng, skriv det blot som en note ved booking.",
  },
  {
    icon: "/infografik_rygning.png",
    title: "Rygning",
    text: "Rygning forbudt indenfor, dog tilladt udenfor.",
  },
];

const aktiviteterdropdown = [
  {
    title: "Check-in og check-ud",
    tagline: "",
    body: "Check-in er muligt fra kl. 15:00, og check-out skal ske senest kl. 11:00 på afrejsedagen. Hvis du ankommer efter receptionens åbningstider, vil du modtage en SMS med nemme instruktioner til selvindtjekning.",
  },
  {
    title: "Udeareal",
    tagline: "",
    body: "Træd ud på vores fantatiske terrasse og i vores hyggelige have og nyd frisk luft, grønne omgivelser og  kolde forfriskninger – det perfekte sted at trække vejret og lade op. Vi har skabt et afslappende udendørsrum, hvor du kan sætte tempoet ned og nyde øjeblikket i rolige, naturskønne rammer, mens vores personale sørger for, at du har alt, hvad du har brug for.",
  },
  {
    title: "Mad og drikke",
    tagline: "",
    body: "Morgenmad er inkluderet i alle værelsespriser ved booking af overnatning. Den serveres mandag til fredag fra kl. 07.30–09.00 og lørdag til søndag fra kl. 08.00–10.00.",
  },
  {
    title: "Internet",
    tagline: "",
    body: "Wi-fi er tilgængeligt overalt på hotellet og er uden beregning.",
  },
  {
    title: "Gratis parkering",
    tagline: "",
    body: "På hotellets gårdplads er der mulighed for fri parkering, dog gælder først-til-mølle princippet. Hvis alle parkeringspladser er optaget, kan man enten parkere tæt på hotellet på havnen, hvor der er en stor offentlig parkeringsplads uden betaling. Derudover er der også mulighed for at parkere på Østervoldgade. Dog er det vigtigt at bemærke, at der er en tidsbegrænsning på 2 timer mellem kl. 09:00 og 18:00.",
  },
  {
    title: "Rygning",
    tagline: "",
    body: "Rygning er forbudt indenfor men der kan ryges udenfor de steder der er opstillet askebæger. ",
  },
  {
    title: "Sprog",
    tagline: "",
    body: "Vi taler dansk, tysk, engelsk og norsk",
  },
];
---

<MainLayout title="Praktisk info">
  <HeroPages title="Praktisk info" leftImage="/praktisk_info_reception.png" leftImageAlt="Petanque" rightImage="/praktisk_illu.svg" rightImageAlt="Villa Gulle tegning" content="For at du kan fokusere på at slappe af og nyde dit ophold, har vi samlet alt det praktiske ét sted. Her finder du svar på de mest stillede spørgsmål så du kan bruge din tid på det, der virkelig betyder noget." subtitle="Villa Gulle" />
  <main class="px-[var(--gutter)] mx-auto max-w-[1340px]">
    <div class="text-center pt-15 md:pt-20">
      <Heading htmlheading="h2" size="large" font="display" stylingclasses="font-light"> Godt at vide før dit ophold </Heading>
    </div>
    <!-- INFO CARDS SECTION -->
    <section id="info-scroll" class="flex md:gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory scroll-x py-3 md:py-7 px-6 md:px-12 lg:px-24 md:grid md:grid-cols-2 lg:grid-cols-3 md:overflow-visible">
      {
        infoCards.map((card) => (
          <div class="min-w-[53%]  md:min-w-0 snap-center">
            <InfoCard icon={card.icon} title={card.title} text={card.text} />
          </div>
        ))
      }
    </section>
    <!-- DOTS I MOBIL -->
    <div id="info-dots" class="flex justify-center gap-2 md:hidden">
      {infoCards.map((_, i) => <button class="dot w-2.5 h-2.5 rounded-full bg-gray-300  transition" data-index={i} aria-label={`Gå til kort ${i + 1}`} />)}
    </div>

    <!-- DROPDOWN / VI SVARE PÅ DET VIGTIGSTE SECTION -->
    <div>
      <DropdownSection heading="Vi svarer på det vigtigste" image="/praktisk_info_stue.png" imageAlt="Af daglistuen" items={aktiviteterdropdown} showButton={false} />
    </div>

    <!-- KONTAKTOPLYSNINGER SECTION-->
    <section class="grid md:grid-cols-2 p-20 md:gap-30">
      <div class="order-1 md:order-2 md:pt-40">
        <Heading htmlheading="h2" size="large" font="display" stylingclasses="mb-3 md:mb-8"> Kontaktoplysninger </Heading>
        <div>
          <div class="flex gap-5">
            <img src="/ikon_adresse.png" class="w-7 h-7 mt-3 md:w-9 md:h-9" alt="Adresse" />
            <Text teksttype="brødtekst" stylingclasses="font-light md:line-clamp-4"> Østervoldgade 44, 5800 Nyborg, Denmark </Text>
          </div>
          <div class="flex gap-5">
            <img src="/ikon_mail.png" class="w-6 h-6 mt-3 md:w-8 md:h-8" alt="Mail" />
            <Text teksttype="brødtekst" stylingclasses="font-light md:line-clamp-4"> Kontakt@hotelvillagulle.dk</Text>
          </div>
          <div class="flex gap-5">
            <img src="/ikon_nummer.png" class="w-3 h-9 mt-3 ml-1 md:w-4 md:h-11" alt="Nummer" />
            <Text teksttype="brødtekst" stylingclasses="font-light md:line-clamp-4 ml-2 md:pl-1"> + 45 23 23 02 19</Text>
          </div>
        </div>
      </div>
      <div class="order-2 md:order-1 flex justify-center">
        <img src="/hotellets_grund.png" class="w-100 pt-10 md:w-140 h-auto" alt="Tegning af hotellets grund" />
      </div>
    </section>

    <style>
      .scroll-x {
        -webkit-overflow-scrolling: touch;
        scrollbar-width: none;
      }

      .scroll-x::-webkit-scrollbar {
        display: none;
      }
    </style>

    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const container = document.querySelector("#info-scroll");
        const dots = document.querySelectorAll("#info-dots .dot");

        if (!container || !dots.length) return;

        function getCards() {
          return container.querySelectorAll(":scope > div");
        }

        function getIndex() {
          const cards = getCards();
          if (!cards.length) return 0;

          const scrollLeft = container.scrollLeft;
          const cardWidth = cards[0].getBoundingClientRect().width;

          const rawIndex = (scrollLeft + cardWidth / 2) / cardWidth;

          return Math.min(dots.length - 1, Math.floor(rawIndex));
        }

        function setActiveDot(index) {
          dots.forEach((dot, i) => {
            if (i === index) {
              dot.classList.add("bg-primary-green-900", "scale-125");
              dot.classList.remove("bg-gray-300");
            } else {
              dot.classList.add("bg-gray-300");
              dot.classList.remove("bg-primary-green-900", "scale-125");
            }
          });
        }

        container.addEventListener("scroll", () => {
          setActiveDot(getIndex());
        });

        dots.forEach((dot) => {
          dot.addEventListener("click", () => {
            const index = Number(dot.dataset.index);
            const cards = getCards();

            const cardWidth = cards[0].getBoundingClientRect().width;

            container.scrollTo({
              left: index * cardWidth,
              behavior: "smooth",
            });

            setActiveDot(index);
          });
        });

        setActiveDot(0);
      });
    </script>
  </main></MainLayout
>
